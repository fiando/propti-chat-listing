JWT_SECRET=replace-with-development-jwt-secret
OPENAI_API_KEY=replace-with-openai-api-key
IMAGE_MODERATION_PROVIDER=openai
GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key
DOKU_CLIENT_ID=replace-with-doku-client-id
DOKU_SECRET_KEY=replace-with-doku-secret-key
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
META_WHATSAPP_ACCESS_TOKEN=replace-with-meta-access-token
META_WHATSAPP_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
META_WHATSAPP_VERIFY_TOKEN=replace-with-meta-verify-token
META_WHATSAPP_APP_SECRET=replace-with-meta-app-secret
META_WHATSAPP_API_VERSION=v23.0
META_WHATSAPP_API_BASE_URL=https://graph.facebook.com
PUBLIC_API_BASE_URL=http://127.0.0.1:3001
WEB_BASE_URL=http://localhost:3000
AWS_ROLE_ARN=replace-with-github-actions-oidc-role-arn-if-needed
# For local development, set additional values only if your local tooling requires them.
# SAM injects DYNAMODB_* tables, S3_MEDIA_BUCKET, DOKU_ENV, and LOG_LEVEL during deploy.
DYNAMODB_WHATSAPP_SESSIONS_TABLE=propti-whatsapp-sessions-dev
DYNAMODB_WHATSAPP_OTP_TABLE=propti-whatsapp-otp-dev
